#+#+#+#+############################################################
# Firebase (Vite)
#
# 1) Create a Firebase project (https://console.firebase.google.com)
# 2) Add a Web App
# 3) Enable Authentication -> Email/Password
# 4) Copy the values below from Firebase project settings
#
# Create a local file named `.env.local` and paste these values.
# Do NOT commit `.env.local`.
########################################################################

# Copy this file to `.env` (or `.env.local`) and replace the placeholders.
# IMPORTANT: These variables are baked into the bundle at build time.
# If you deploy via CI (GitHub Actions/Firebase Hosting GitHub integration),
# you must provide these as build-time environment variables/secrets.

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef1234567890
